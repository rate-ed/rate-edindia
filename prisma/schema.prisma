generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String?
  name           String?
  role           String          @default("PARENT")
  image          String?
  emailVerified  DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  bookings       Booking[]       @relation("ParentBookings")
  payments       Payment[]
  sessions       Session[]
  teacherProfile TeacherProfile?
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model TeacherProfile {
  id             String         @id @default(uuid())
  userId         String         @unique
  bio            String?
  qualifications String?
  experience     Int?
  fees           Float?
  rating         Float          @default(0)
  ratingCount    Int            @default(0)
  photo          String?
  aadharDoc      String?
  degreeDoc      String?
  subjects       String?
  location       String         @default("")
  approved       Boolean        @default(false)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  availability   Availability[]
  bookings       Booking[]      @relation("TeacherBookings")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Availability {
  id        String         @id @default(uuid())
  teacherId String
  dayOfWeek Int
  startTime String
  endTime   String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

model Booking {
  id        String         @id @default(uuid())
  parentId  String
  teacherId String
  date      String
  time      String
  subject   String?
  status    String         @default("PENDING")
  notes     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  teacher   TeacherProfile @relation("TeacherBookings", fields: [teacherId], references: [id])
  parent    User           @relation("ParentBookings", fields: [parentId], references: [id])
  payment   Payment?
}

model Payment {
  id                String   @id @default(uuid())
  userId            String
  bookingId         String   @unique
  amount            Float
  currency          String   @default("INR")
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String   @default("PENDING")
  refundStatus      String?
  createdAt         DateTime @default(now())
  booking           Booking  @relation(fields: [bookingId], references: [id])
  user              User     @relation(fields: [userId], references: [id])
}
